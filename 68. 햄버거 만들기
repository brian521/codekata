#include <string>
#include <vector>

using namespace std;

int solution(vector<int> ingredient) {
    int answer = 0;
    
    vector<int> stack;
    int start = 0;
    int i = 0;
    while(ingredient.size() > i)
    {
        if(stack.empty())
        {
            if(ingredient[i] == 1)
            {
                stack.push_back(1);
            }
        }
        else if(ingredient[i] == 1)
        {
            if(stack.back() == 3)
            {
                answer++;
                stack.pop_back();
                stack.pop_back();
                stack.pop_back();
            }
            else
            {
                stack.push_back(1);
            }
        }
        else if(ingredient[i] == 2)
        {
            if(stack.back() == 1)
            {
                stack.push_back(2);
            }
            else
            {
                stack.clear();
            }
        }
        else if(ingredient[i] == 3)
        {
            if(stack.back() == 2)
            {
                stack.push_back(3);
            }
            else
            {
                stack.clear();
            }
        }
        
        i++;
    }
    
    return answer;
}
